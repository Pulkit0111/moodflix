TMDB_API_KEY=your_tmdb_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
FRONTEND_URL=http://localhost:3000

# Local dev: file-based ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# Production (Chroma Cloud): leave CHROMA_PERSIST_DIR unset, fill these instead
# Get from: cloud.trychroma.com
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=default_database

# Local dev: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-service-account.json

# Production (Railway): base64-encoded service account JSON
# Generate with: base64 -i path/to/firebase-service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_JSON=
